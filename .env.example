# FAA SWIM NMS JMS consumer configuration lives in nms-jumpstart.conf
# (created from your subscription details; kept out of git via .gitignore).
# It contains: providerUrl, queue, connectionFactory, username, password, vpn.
#
# Request access and credentials at https://nms.aim.faa.gov/ or email notams@faa.gov

# Bridge filter: which airport identifiers count as "Denver area".
# ICAO codes and domestic location designators are both valid.
# DENVER_AIRPORTS=KDEN,DEN,KAPA,KBJC,KFTG,KRMV

# Radius used when a NOTAM includes coordinates but no known airport identifier.
# TFR_SEARCH_RADIUS_NM=50

# Override where the JMS consumer writes AIXM message files and where the bridge writes its JSON cache.
# NMS_LOG_DIR=log
# NMS_DATA_DIR=data

# How often the bridge rescans the log directory (milliseconds).
# NMS_BRIDGE_INTERVAL_MS=30000

# Optional: coordinate override for weather/alerts
# WEATHER_LAT=39.7392
# WEATHER_LON=-104.9903
